MergeSort(values) = {
    list = atoms(values)
    llist = list.take(list.count div 2)
    rlist = list.skip(list.count div 2)
    Output = if(
        list.count <= 1,
        list,
        Merge(
            llist.MergeSort,
            rlist.MergeSort
        )
    )
}

